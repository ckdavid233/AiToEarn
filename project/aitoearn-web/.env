# API URL（浏览器请求同源 /api，由 next.config rewrites 转到 NEXT_PUBLIC_PROXY_URL）
NEXT_PUBLIC_API_URL="/api"

# 本地 Docker：Nginx 8080 反代 aitoearn-server + aitoearn-ai（与 next.config.mjs 中 rewrites 对应）
NEXT_PUBLIC_PROXY_URL=http://localhost:8080

# OSS URL（自部署通过 nginx 代理到本地 rustfs）
NEXT_PUBLIC_OSS_URL="/oss/"

# OSS URL 代理
NEXT_PUBLIC_OSS_URL_PROXY="/ossProxy/"

# s3 URL 1
NEXT_PUBLIC_S3_URL="https://aitoearn.s3.ap-southeast-1.amazonaws.com/"
# s3 代理
NEXT_PUBLIC_S3_PROXY="/s3Proxy/"

# 本地自部署免登录模式（不发送 Authorization，不做自动登录与用户初始化）
NEXT_PUBLIC_DISABLE_AUTH="true"